{
  "name": "shear-plate",
  "version": "0.1.0",
  "description": "Cross-device clipboard sync tool",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc --noEmit",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "dist:win": "npm run build && electron-builder --win portable --x64 --publish never"
  },
  "build": {
    "appId": "com.wayhim.shearplate",
    "productName": "ShearPlate",
    "icon": "resources/icons/icon.png",
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.md",
      "!**/*.markdown",
      "!node_modules/**/{test,tests,__tests__,example,examples,doc,docs}/**",
      "!node_modules/sql.js/dist/*debug*",
      "!node_modules/lucide-react/dist/umd/**",
      "!**/.git/**",
      "!**/.idea/**",
      "!**/.playwright-mcp/**",
      "!**/arboard/**",
      "!**/docs/**"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": "-",
      "icon": "resources/icons/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "icon": "resources/icons/icon.ico",
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-virtual": "^3.13.4",
    "sql.js": "^1.11.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/sql.js": "^1.4.9",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
